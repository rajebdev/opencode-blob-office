{
  "name": "opencode-blob-office",
  "version": "2.2.2",
  "description": "Visualize OpenCode sessions as animated blob characters",
  "type": "module",
  "bin": {
    "opencode-blob-office": "bin/opencode-blob-office.js"
  },
  "files": [
    "bin/opencode-blob-office.js",
    "blob-office.ts",
    "blob-office.html",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "visualization",
    "agent",
    "ai"
  ],
  "author": "cbrunnkvist",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cbrunnkvist/opencode-blob-office.git"
  },
  "scripts": {
    "plugin-installer": "bash install.sh",
    "mock-server": "bun run blob-office-mock-server.ts 2727",
    "test": "bun tests/run-tests.ts",
    "test:unit": "bun tests/run-tests.ts --unit",
    "test:integration": "bun tests/run-tests.ts --integration",
    "test:e2e": "bun tests/run-tests.ts --e2e",
    "test:visual": "playwright test",
    "test:visual:ui": "playwright test --ui",
    "test:visual:headed": "playwright test --headed",
    "test:states": "playwright test tests/e2e/state-capture.spec.ts",
    "test:watch": "bun tests/run-tests.ts --watch",
    "preview:capture": "playwright test --project=previews",
    "preview:convert": "bash scripts/convert-previews.sh",
    "preview:generate": "bun run preview:capture && bun run preview:convert"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
